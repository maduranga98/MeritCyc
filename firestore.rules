rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // Helper functions
    // =========================================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function role() {
      return request.auth.token.role;
    }

    // Returns the companyId from the caller's JWT claims.
    // Named callerCompanyId to avoid shadowing {companyId} path wildcards.
    function callerCompanyId() {
      return request.auth.token.companyId;
    }

    function isSameCompany(cId) {
      return isSignedIn() && callerCompanyId() == cId;
    }

    function isHrOrAdmin(cId) {
      return isSameCompany(cId) &&
             (role() == 'super_admin' || role() == 'hr_admin');
    }

    function isPlatformAdmin() {
      return isSignedIn() && role() == 'platform_admin';
    }

    // =========================================================================
    // Platform-level collections
    // =========================================================================

    match /companies/{companyId} {
      allow read: if isPlatformAdmin() ||
                     (isSignedIn() && callerCompanyId() == companyId);
      allow write: if false; // Cloud Functions only
    }

    // =========================================================================
    // Feature 1.2: HR Invite System
    // =========================================================================

    match /companies/{companyId}/invites/{inviteId} {
      allow read: if isHrOrAdmin(companyId);
      allow write: if false; // Cloud Functions only
    }

    // =========================================================================
    // Feature 1.3: QR Self-Registration
    // =========================================================================

    // Public read — unauthenticated company code validation during signup.
    match /companies/{companyId}/registration/{docId} {
      allow read: if true;
      allow write: if false; // Cloud Functions only
    }

    // Public read — unauthenticated join form needs the department list.
    match /companies/{companyId}/departments/{deptId} {
      allow read: if true;
      allow write: if false; // Cloud Functions only
    }

    // =========================================================================
    // Feature 1.5: HR Approval System
    // =========================================================================

    match /companies/{companyId}/pendingRegistrations/{id} {
      allow read: if isHrOrAdmin(companyId);
      allow write: if false; // Cloud Functions only
    }

    // =========================================================================
    // Company Settings
    // =========================================================================

    match /companies/{companyId}/settings/{settingId} {
      // All authenticated company members read the security doc (idle-timeout,
      // session policy). Only HR / super_admin read other settings docs.
      allow read: if isHrOrAdmin(companyId) ||
                     isPlatformAdmin() ||
                     (settingId == 'security' && isSameCompany(companyId));
      allow write: if false; // Cloud Functions only
    }

    // =========================================================================
    // Salary Bands — sensitive compensation data, HR / platform admin only
    // =========================================================================

    match /companies/{companyId}/salaryBands/{bandId} {
      allow read: if isHrOrAdmin(companyId) || isPlatformAdmin();
      allow write: if false; // Cloud Functions only
    }

    // =========================================================================
    // Career Paths — all company members read
    // =========================================================================

    match /companies/{companyId}/careerPaths/{pathId} {
      allow read: if isSignedIn() && isSameCompany(companyId);
      allow write: if false; // Cloud Functions only
    }

    // =========================================================================
    // Fairness Reports — HR / platform admin only
    // =========================================================================

    match /companies/{companyId}/fairnessReports/{reportId} {
      allow read: if isHrOrAdmin(companyId) || isPlatformAdmin();
      allow write: if false; // Cloud Functions only
    }

    // =========================================================================
    // Generated Reports — HR / platform admin only
    // =========================================================================

    match /companies/{companyId}/reports/{reportId} {
      allow read: if isHrOrAdmin(companyId) || isPlatformAdmin();
      allow write: if false; // Cloud Functions only
    }

    // =========================================================================
    // Rate limits (internal — Cloud Functions only)
    // =========================================================================

    match /rateLimits/{key} {
      allow read:  if false;
      allow write: if false;
    }

    // =========================================================================
    // Users collection
    // =========================================================================

    match /users/{uid} {
      allow read: if isSignedIn() && (
        request.auth.uid == uid ||
        isHrOrAdmin(resource.data.companyId) ||
        isPlatformAdmin()
      );
      allow write: if false; // Cloud Functions only
    }

    // =========================================================================
    // User sub-collections
    // =========================================================================

    // Notifications — own user only
    match /users/{userId}/notifications/{notifId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false; // Cloud Functions only
    }

    // Increment stories — own user only (career page recommendations)
    match /users/{userId}/incrementStories/{storyId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false; // Cloud Functions only
    }

    // Career maps — own user or HR / admin of the same company
    match /users/{userId}/careerMap/{mapId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId ||
        isHrOrAdmin(resource.data.companyId)
      );
      allow write: if false; // Cloud Functions only
    }

    // =========================================================================
    // Audit logs — HR / admin and platform admin read
    // =========================================================================

    match /auditLogs/{logId} {
      allow read: if isPlatformAdmin() ||
                     isHrOrAdmin(resource.data.companyId);
      allow write: if false; // Cloud Functions only
    }

    // =========================================================================
    // Cycles — HR / admin / manager / employee read (needed for eval workflow
    // and employee career page); all writes via Cloud Functions
    // =========================================================================

    match /cycles/{cycleId} {
      allow read: if isPlatformAdmin() ||
                     (isSignedIn() && isSameCompany(resource.data.companyId));
      allow write: if false; // Cloud Functions only
    }

    // Budget simulations — HR / admin only; uses get() to resolve the
    // parent cycle's companyId without storing it redundantly on each sim doc.
    match /cycles/{cycleId}/simulations/{simId} {
      allow read: if isPlatformAdmin() ||
                     isHrOrAdmin(
                       get(/databases/$(database)/documents/cycles/$(cycleId)).data.companyId
                     );
      allow write: if false; // Cloud Functions only
    }

    // =========================================================================
    // Evaluations — scoped by role
    //   Platform admin  : all
    //   HR / super_admin: all in their company
    //   Manager         : evaluations they own (managerId == uid)
    //   Employee        : own evaluations once submitted / finalized / overridden
    // =========================================================================

    match /evaluations/{evalId} {
      allow read: if isPlatformAdmin() ||
                     isHrOrAdmin(resource.data.companyId) ||
                     (isSignedIn() &&
                      request.auth.uid == resource.data.managerId &&
                      isSameCompany(resource.data.companyId)) ||
                     (isSignedIn() &&
                      request.auth.uid == resource.data.employeeUid &&
                      isSameCompany(resource.data.companyId) &&
                      resource.data.status in ['submitted', 'finalized', 'overridden']);
      allow write: if false; // Cloud Functions only
    }

    // =========================================================================
    // Catch-all: deny everything not explicitly matched above
    // =========================================================================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
