rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // Helper functions
    // =========================================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function hasClaim(field) {
      return request.auth.token[field] != null;
    }

    function role() {
      return request.auth.token.role;
    }

    function companyId() {
      return request.auth.token.companyId;
    }

    function isSameCompany(cId) {
      return isSignedIn() && companyId() == cId;
    }

    function isHrOrAdmin(cId) {
      return isSameCompany(cId) &&
             (role() == 'super_admin' || role() == 'hr_admin');
    }

    function isPlatformAdmin() {
      return isSignedIn() && role() == 'platform_admin';
    }

    // =========================================================================
    // Platform-level collections
    // =========================================================================

    match /companies/{companyId} {
      allow read: if isPlatformAdmin() ||
                     (isSignedIn() && companyId() == companyId);
      allow write: if false; // Cloud Functions only
    }

    // =========================================================================
    // Feature 1.2: HR Invite System
    // =========================================================================

    match /companies/{companyId}/invites/{inviteId} {
      allow read: if isHrOrAdmin(companyId);
      allow write: if false; // Cloud Functions only
    }

    // =========================================================================
    // Feature 1.3: QR Self-Registration
    // =========================================================================

    // QR config doc: /companies/{companyId}/registration/{companyId}
    // HR and super_admin of the same company may read (to display QR manager).
    // Writes are Cloud Functions only.
    match /companies/{companyId}/registration/{docId} {
      allow read: if isHrOrAdmin(companyId);
      allow write: if false; // Cloud Functions only
    }

    // Pending registrations: /companies/{companyId}/pendingRegistrations/{email}
    // Contains hashed OTP — no client should ever read or write this.
    match /companies/{companyId}/pendingRegistrations/{email} {
      allow read:  if false; // Cloud Functions only
      allow write: if false; // Cloud Functions only
    }

    // Departments: public read so the join form can populate the dropdown.
    // Only HR/admin can write (through Cloud Functions in practice).
    match /companies/{companyId}/departments/{deptId} {
      allow read: if true; // Public — used by unauthenticated join flow
      allow write: if false; // Cloud Functions only
    }

    // =========================================================================
    // Rate limits (internal — Cloud Functions only)
    // =========================================================================

    match /rateLimits/{key} {
      allow read:  if false;
      allow write: if false;
    }

    // =========================================================================
    // Users collection
    // =========================================================================

    match /users/{uid} {
      allow read: if isSignedIn() && (
        request.auth.uid == uid ||
        isHrOrAdmin(resource.data.companyId) ||
        isPlatformAdmin()
      );
      allow write: if false; // Cloud Functions only
    }

    // =========================================================================
    // Audit logs (append via Cloud Functions, read by platform admin)
    // =========================================================================

    match /auditLogs/{logId} {
      allow read: if isPlatformAdmin() ||
                     isHrOrAdmin(resource.data.companyId);
      allow write: if false;
    }

    // =========================================================================
    // Catch-all: deny everything not explicitly matched above
    // =========================================================================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
