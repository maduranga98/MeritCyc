rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // This rule allows anyone with your Firestore database reference to view, edit,
    // and delete all data in your Firestore database. It is useful for getting
    // started, but it is configured to expire after 30 days because it
    // leaves your app open to attackers. At that time, all client
    // requests to your Firestore database will be denied.
    //
    // Make sure to write security rules for your app before that time, or else
    // all client requests to your Firestore database will be denied until you Update
    // your rules
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2026, 5, 3);
    }

    // Feature 1.2: HR Invite System
    match /companies/{companyId}/invites/{inviteId} {
      // allow read by super_admin or hr_admin of the same company
      allow read: if request.auth != null &&
                  request.auth.token.companyId == companyId &&
                  (request.auth.token.role == 'super_admin' || request.auth.token.role == 'hr_admin');

      // writes are only allowed from Cloud Functions (which bypass these rules)
      allow write: if false;
    }

    // Feature 1.5: HR Approval System
    match /companies/{companyId}/pendingRegistrations/{id} {
      // allow read by hr_admin or super_admin of the same company
      allow read: if request.auth != null &&
                  request.auth.token.companyId == companyId &&
                  (request.auth.token.role == 'hr_admin' || request.auth.token.role == 'super_admin');

      // writes are only allowed from Cloud Functions
      allow write: if false;
    }
  }
}